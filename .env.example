# Compliance Advisory & Triage Agent — environment variables
# Copy this file to .env and fill in the values before running.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Groq API key — obtain from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ---------------------------------------------------------------------------
# Optional overrides (defaults shown)
# ---------------------------------------------------------------------------

# Groq model ID — see https://console.groq.com/docs/models
# Default: llama-3.1-8b-instant  (fast, low-cost, production tier)
# Alternative: llama-3.3-70b-versatile  (higher quality, slower)
# GROQ_MODEL=llama-3.1-8b-instant

# Groq API base URL (no trailing slash)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Request timeout in seconds
# GROQ_TIMEOUT=120

# ChromaDB persistence directory (relative to project root)
# CHROMA_PERSIST_DIR=./data/chroma_db

# Policy documents directory
# POLICIES_DIR=data/policies

# Minimum cosine similarity score for a retrieval match (0.0–1.0)
# CONFIDENCE_THRESHOLD=0.35
